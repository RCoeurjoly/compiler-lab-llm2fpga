From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Roland Coeurjoly <rolandcoeurjoly@gmail.com>
Date: Tue, 31 Mar 2026 19:05:00 +0200
Subject: [PATCH 9/9] Handle dense resource globals in FlattenMemRefs

---
diff --git a/lib/Transforms/FlattenMemRefs.cpp b/lib/Transforms/FlattenMemRefs.cpp
index e04ec14e2..30b670053 100644
--- a/lib/Transforms/FlattenMemRefs.cpp
+++ b/lib/Transforms/FlattenMemRefs.cpp
@@ -20,6 +20,8 @@
 #include "mlir/Dialect/Func/IR/FuncOps.h"
 #include "mlir/Dialect/MemRef/IR/MemRef.h"
 #include "mlir/Dialect/Utils/ReshapeOpsUtils.h"
+#include "mlir/IR/BuiltinAttributes.h"
+#include "mlir/IR/DialectResourceBlobManager.h"
 #include "mlir/IR/BuiltinDialect.h"
 #include "mlir/IR/BuiltinTypes.h"
 #include "mlir/IR/ImplicitLocOpBuilder.h"
@@ -204,22 +205,35 @@
       return failure();
     MemRefType newType = getFlattenedMemRefType(type);
 
-    auto cstAttr =
-        llvm::dyn_cast_or_null<DenseElementsAttr>(op.getConstantInitValue());
+    ElementsAttr cstAttr = op.getConstantInitValue();
+    if (!cstAttr)
+      return rewriter.notifyMatchFailure(op, "expected constant global init");
 
-    SmallVector<Attribute> flattenedVals;
-    for (auto attr : cstAttr.getValues<Attribute>())
-      flattenedVals.push_back(attr);
+    RankedTensorType tensorType = RankedTensorType::get(
+        {newType.getNumElements()}, type.getElementType());
+    Attribute newInitValue;
+
+    if (auto denseAttr = llvm::dyn_cast<DenseElementsAttr>(cstAttr)) {
+      SmallVector<Attribute> flattenedVals;
+      for (auto attr : denseAttr.getValues<Attribute>())
+        flattenedVals.push_back(attr);
+
+      newInitValue = DenseElementsAttr::get(tensorType, flattenedVals);
+    } else if (auto resourceAttr =
+                   llvm::dyn_cast<DenseResourceElementsAttr>(cstAttr)) {
+      // Flattening only changes the shaped type metadata; the backing resource
+      // blob already stores the elements in the required linearized order.
+      newInitValue =
+          DenseResourceElementsAttr::get(tensorType, resourceAttr.getRawHandle());
+    } else {
+      return rewriter.notifyMatchFailure(op, "unsupported global init attr");
+    }
 
     auto newTypeAttr = TypeAttr::get(newType);
     auto newNameStr = getFlattenedMemRefName(op.getConstantAttrName(), type);
     auto newName = rewriter.getStringAttr(newNameStr);
     globalNameMap[op.getSymNameAttr()] = newName;
 
-    RankedTensorType tensorType = RankedTensorType::get(
-        {static_cast<int64_t>(flattenedVals.size())}, type.getElementType());
-    auto newInitValue = DenseElementsAttr::get(tensorType, flattenedVals);
-
     rewriter.replaceOpWithNewOp<memref::GlobalOp>(
         op, newName, op.getSymVisibilityAttr(), newTypeAttr, newInitValue,
         op.getConstantAttr(), op.getAlignmentAttr());
-- 
2.53.0
