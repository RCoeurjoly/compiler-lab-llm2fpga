+    def _copy_tensor_meta_from_input(self, node: Node, input_node: Node):
+        input_tm = input_node.meta.get("tensor_meta")
+        if input_tm is None:
+            return
+        node.meta["tensor_meta"] = TensorMetadata(
+            shape=input_tm.shape,
+            dtype=input_tm.dtype,
+            requires_grad=input_tm.requires_grad,
+            stride=input_tm.stride,
+            memory_format=input_tm.memory_format,
+            is_quantized=input_tm.is_quantized,
+            qparams=input_tm.qparams,
+        )
+
+    def _infer_matmul_shape(self, lhs_shape, rhs_shape):
+        lhs_shape = list(lhs_shape)
+        rhs_shape = list(rhs_shape)
+        if len(lhs_shape) == 1 and len(rhs_shape) == 1:
+            return []
+        if len(lhs_shape) == 1:
+            return rhs_shape[:-2] + [rhs_shape[-1]]
+        if len(rhs_shape) == 1:
+            return lhs_shape[:-1]
+        batch_shape = list(
+            torch.broadcast_shapes(
+                torch.Size(lhs_shape[:-2]), torch.Size(rhs_shape[:-2])
+            )
+        )
+        return batch_shape + [lhs_shape[-2], rhs_shape[-1]]
+
+    def _set_quantized_tensor_meta_from_matmul(self, node: Node):
+        if not isinstance(node.args[0], torch_fx.Node):
+            return
+        lhs_tm = node.args[0].meta.get("tensor_meta")
+        if lhs_tm is None:
+            return
+        shape = self._infer_matmul_shape(
+            self._infer_node_shape(node.args[0]),
+            self._infer_node_shape(node.args[1]),
+        )
+        self._set_quantized_tensor_meta_from_input(
+            node,
+            node.args[0],
+            dtype=lhs_tm.dtype,
+            shape=shape,
+        )
