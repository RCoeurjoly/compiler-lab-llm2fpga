diff --git a/test/Dialect/Torch/match-native-fx-quantized-layernorm.mlir b/test/Dialect/Torch/match-native-fx-quantized-layernorm.mlir
new file mode 100644
index 0000000..944b88f
--- /dev/null
+++ b/test/Dialect/Torch/match-native-fx-quantized-layernorm.mlir
@@ -0,0 +1,19 @@
+// RUN: torch-mlir-opt --torch-match-quantized-custom-ops %s | FileCheck %s
+
+// CHECK-LABEL: func.func @quantized_layer_norm
+func.func @quantized_layer_norm(%arg0: !torch.vtensor<[2,4,8],!torch.quint8>) -> !torch.vtensor<[2,4,8],!torch.quint8> {
+  %int8 = torch.constant.int 8
+  %list = torch.prim.ListConstruct %int8 : (!torch.int) -> !torch.list<int>
+  %weight = torch.vtensor.literal(dense<1.0> : tensor<8xf32>) : !torch.vtensor<[8],f32>
+  %bias = torch.vtensor.literal(dense<0.0> : tensor<8xf32>) : !torch.vtensor<[8],f32>
+  %eps = torch.constant.float 1.000000e-05
+  %scale = torch.constant.float 3.125000e-02
+  %zero_point = torch.constant.int 64
+  // CHECK-DAG: %[[TRUE:.+]] = torch.constant.bool true
+  // CHECK-DAG: %[[DEQUANT:.+]] = torch.aten.dequantize.self %arg0 : !torch.vtensor<[2,4,8],!torch.quint8> -> !torch.vtensor<[2,4,8],f32>
+  // CHECK-DAG: %[[DTYPE:.+]] = torch.constant.int 13
+  // CHECK: %[[LN:.+]] = torch.aten.layer_norm %[[DEQUANT]], %{{.+}}, %{{.+}}, %{{.+}}, %{{.+}}, %[[TRUE]] : !torch.vtensor<[2,4,8],f32>, !torch.list<int>, !torch.vtensor<[8],f32>, !torch.vtensor<[8],f32>, !torch.float, !torch.bool -> !torch.vtensor<[2,4,8],f32>
+  // CHECK: %[[Q:.+]] = torch.aten.quantize_per_tensor %[[LN]], %{{.+}}, %{{.+}}, %[[DTYPE]] : !torch.vtensor<[2,4,8],f32>, !torch.float, !torch.int, !torch.int -> !torch.vtensor<[2,4,8],!torch.quint8>
+  %0 = torch.operator "torch.quantized.layer_norm"(%arg0, %list, %weight, %bias, %eps, %scale, %zero_point) : (!torch.vtensor<[2,4,8],!torch.quint8>, !torch.list<int>, !torch.vtensor<[8],f32>, !torch.vtensor<[8],f32>, !torch.float, !torch.float, !torch.int) -> !torch.vtensor<[2,4,8],!torch.quint8>
+  return %0 : !torch.vtensor<[2,4,8],!torch.quint8>
+}
