+class QuantizeAttentionSoftmaxOutput
+    : public OpRewritePattern<AtenSoftmaxIntOp> {
+public:
+  using OpRewritePattern<AtenSoftmaxIntOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(AtenSoftmaxIntOp op,
+                                PatternRewriter &rewriter) const override {
+    auto resultTy = dyn_cast<BaseTensorType>(op.getType());
+    if (!resultTy || !resultTy.hasDtype() ||
+        !isa<mlir::FloatType>(resultTy.getDtype()))
+      return failure();
+
+    bool hasNonQuantizedUser = llvm::any_of(op.getResult().getUsers(), [](Operation *user) {
+      return !isa<AtenQuantizePerTensorOp, AtenIntReprOp,
+                  Aten_MakePerTensorQuantizedTensorOp,
+                  AtenDequantizeTensorOp>(user);
+    });
+    if (!hasNonQuantizedUser)
+      return rewriter.notifyMatchFailure(op, "softmax is already wrapped in quantize/dequantize");
+
+    bool hasAttentionMatmulUser =
+        llvm::any_of(op.getResult().getUsers(), [](Operation *user) {
+          return isa<AtenMatmulOp, AtenMmOp>(user);
+        });
+    if (!hasAttentionMatmulUser)
+      return rewriter.notifyMatchFailure(
+          op, "softmax does not feed a quantizable attention matmul");
+
+    auto getInputQTensor = [](Value value) -> Value {
+      Operation *definingOp = value.getDefiningOp();
+      if (!definingOp)
+        return {};
+      if (auto divScalar = dyn_cast<AtenDivScalarOp>(definingOp))
+        definingOp = divScalar.getSelf().getDefiningOp();
+      if (!definingOp ||
+          !isa<AtenDequantizeSelfOp, AtenDequantizeTensorOp>(definingOp))
+        return {};
+      return definingOp->getOperand(0);
+    };
+
+    Value inputQTensor = getInputQTensor(op.getSelf());
+    if (!inputQTensor)
+      return rewriter.notifyMatchFailure(
+          op, "softmax input is not a dequantized quantized tensor");
+
+    auto *inputQuantOp = inputQTensor.getDefiningOp();
+    if (!inputQuantOp ||
+        !isa<Aten_MakePerTensorQuantizedTensorOp, AtenQuantizePerTensorOp>(
+            inputQuantOp))
+      return rewriter.notifyMatchFailure(
+          op, "softmax input is not backed by a per-tensor quantized op");
+
+    auto inputQTy = dyn_cast<BaseTensorType>(inputQTensor.getType());
+    if (!inputQTy || !inputQTy.hasDtype() ||
+        !isa<QInt8Type, QUInt8Type, QInt32Type>(inputQTy.getDtype()))
+      return failure();
+
+    Location loc = op.getLoc();
+    auto qOutDtype = rewriter.getType<QUInt8Type>();
+    auto qOutTy = cast<BaseTensorType>(
+        resultTy.getWithSizesAndDtype(resultTy.getOptionalSizes(), qOutDtype));
+    auto storageTy = cast<BaseTensorType>(resultTy.getWithSizesAndDtype(
+        resultTy.getOptionalSizes(),
+        IntegerType::get(rewriter.getContext(), 8, IntegerType::Unsigned)));
+
+    Value softmax = AtenSoftmaxIntOp::create(rewriter, loc, resultTy,
+                                             op.getSelf(), op.getDim(),
+                                             op.getDtype());
+    Value scale = ConstantFloatOp::create(
+        rewriter, loc, rewriter.getF64FloatAttr(1.0 / 256.0));
+    Value zero = ConstantIntOp::create(
+        rewriter, loc, rewriter.getType<Torch::IntType>(),
+        rewriter.getIntegerAttr(rewriter.getIntegerType(64), 0));
+    Value dtype = getDtypeIntValueForType(rewriter, loc, qOutDtype);
+
+    Value quant = AtenQuantizePerTensorOp::create(rewriter, loc, qOutTy,
+                                                  softmax, scale, zero, dtype);
+    Value intRepr =
+        AtenIntReprOp::create(rewriter, loc, storageTy, quant);
+    Value qSoftmax = Aten_MakePerTensorQuantizedTensorOp::create(
+        rewriter, loc, qOutTy, intRepr, scale, zero);
+    rewriter.replaceOpWithNewOp<AtenDequantizeTensorOp>(op, resultTy, qSoftmax);
+    return success();
+  }
+};
