+class DecomposeLinearForQuantFusion : public OpRewritePattern<AtenLinearOp> {
+public:
+  using OpRewritePattern<AtenLinearOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(AtenLinearOp op,
+                                PatternRewriter &rewriter) const override {
+    Location loc = op.getLoc();
+    Value input = op.getInput();
+    Value weight = op.getWeight();
+    Value bias = op.getBias();
+
+    auto inputType = dyn_cast<BaseTensorType>(input.getType());
+    auto weightType = dyn_cast<BaseTensorType>(weight.getType());
+    if (!inputType || !inputType.hasSizes() || !weightType ||
+        !weightType.hasSizes())
+      return failure();
+
+    auto transposeWeight = [&]() -> Value {
+      SmallVector<int64_t> transposeShape =
+          llvm::to_vector(llvm::reverse(weightType.getSizes()));
+      Type transposeType = weightType.getWithSizesAndDtype(
+          llvm::ArrayRef(transposeShape), weightType.getOptionalDtype());
+      Value dim0 =
+          ConstantIntOp::create(rewriter, loc, rewriter.getI64IntegerAttr(0));
+      Value dim1 =
+          ConstantIntOp::create(rewriter, loc, rewriter.getI64IntegerAttr(1));
+      return AtenTransposeIntOp::create(rewriter, loc, transposeType, weight,
+                                        dim0, dim1);
+    };
+
+    auto weightRank = weightType.getSizes().size();
+    if (isa<Torch::NoneType>(bias.getType())) {
+      if (weightRank == 1) {
+        rewriter.replaceOpWithNewOp<AtenMatmulOp>(op, op.getType(), input,
+                                                  weight);
+        return success();
+      }
+      if (weightRank == 2) {
+        rewriter.replaceOpWithNewOp<AtenMatmulOp>(op, op.getType(), input,
+                                                  transposeWeight());
+        return success();
+      }
+      return failure();
+    }
+
+    auto biasType = dyn_cast<BaseTensorType>(bias.getType());
+    if (!biasType || !biasType.hasSizes() || biasType.getSizes().size() != 1 ||
+        weightRank != 2)
+      return failure();
+
+    Value matmul = AtenMatmulOp::create(rewriter, loc, op.getType(), input,
+                                        transposeWeight());
+    Value alpha =
+        ConstantIntOp::create(rewriter, loc, rewriter.getI64IntegerAttr(1));
+    rewriter.replaceOpWithNewOp<AtenAddTensorOp>(op, op.getType(), matmul, bias,
+                                                 alpha);
+    return success();
+  }
+};
