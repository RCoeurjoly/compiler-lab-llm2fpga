+class QuantizeDecomposedAttentionSoftmaxOutput
+    : public OpRewritePattern<AtenDivTensorOp> {
+public:
+  using OpRewritePattern<AtenDivTensorOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(AtenDivTensorOp op,
+                                PatternRewriter &rewriter) const override {
+    auto resultTy = dyn_cast<BaseTensorType>(op.getType());
+    if (!resultTy || !resultTy.hasDtype() ||
+        !isa<mlir::FloatType>(resultTy.getDtype()))
+      return failure();
+
+    bool hasNonQuantizedUser = llvm::any_of(op.getResult().getUsers(), [](Operation *user) {
+      return !isa<AtenQuantizePerTensorOp, AtenIntReprOp,
+                  Aten_MakePerTensorQuantizedTensorOp,
+                  AtenDequantizeTensorOp>(user);
+    });
+    if (!hasNonQuantizedUser)
+      return rewriter.notifyMatchFailure(
+          op, "decomposed softmax is already wrapped in quantize/dequantize");
+
+    auto exp = op.getSelf().getDefiningOp<AtenExpOp>();
+    if (!exp)
+      return failure();
+
+    auto sum = op.getOther().getDefiningOp<AtenSumDimIntListOp>();
+    if (!sum || sum.getSelf() != exp.getResult())
+      return failure();
+
+    auto sub = exp.getSelf().getDefiningOp<AtenSubTensorOp>();
+    if (!sub)
+      return failure();
+
+    auto max = sub.getOther().getDefiningOp<AtenMaxDimOp>();
+    if (!max || sub.getSelf() != max.getSelf() ||
+        sub.getOther() != max->getResult(0))
+      return failure();
+
+    Location loc = op.getLoc();
+    auto qOutDtype = rewriter.getType<QUInt8Type>();
+    auto qOutTy = cast<BaseTensorType>(
+        resultTy.getWithSizesAndDtype(resultTy.getOptionalSizes(), qOutDtype));
+    auto storageTy = cast<BaseTensorType>(resultTy.getWithSizesAndDtype(
+        resultTy.getOptionalSizes(),
+        IntegerType::get(rewriter.getContext(), 8, IntegerType::Unsigned)));
+
+    Value scale = ConstantFloatOp::create(
+        rewriter, loc, rewriter.getF64FloatAttr(1.0 / 256.0));
+    Value zero = ConstantIntOp::create(
+        rewriter, loc, rewriter.getType<Torch::IntType>(),
+        rewriter.getIntegerAttr(rewriter.getIntegerType(64), 0));
+    Value dtype = getDtypeIntValueForType(rewriter, loc, qOutDtype);
+
+    OpBuilder::InsertionGuard guard(rewriter);
+    rewriter.setInsertionPointAfter(op);
+    Value quant = AtenQuantizePerTensorOp::create(rewriter, loc, qOutTy,
+                                                  op.getResult(), scale, zero,
+                                                  dtype);
+    Value intRepr =
+        AtenIntReprOp::create(rewriter, loc, storageTy, quant);
+    Value qSoftmax = Aten_MakePerTensorQuantizedTensorOp::create(
+        rewriter, loc, qOutTy, intRepr, scale, zero);
+    Value dequant =
+        AtenDequantizeTensorOp::create(rewriter, loc, resultTy, qSoftmax);
+    rewriter.replaceAllUsesExcept(op.getResult(), dequant, quant.getDefiningOp());
+    return success();
+  }
+};
 
