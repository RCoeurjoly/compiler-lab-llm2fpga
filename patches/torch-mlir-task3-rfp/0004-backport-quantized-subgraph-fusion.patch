+class RequantizeQint32ToQint8 : public OpRewritePattern<AtenQuantizePerTensorOp> {
+public:
+  using OpRewritePattern<AtenQuantizePerTensorOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(AtenQuantizePerTensorOp op,
+                                PatternRewriter &rewriter) const override {
+    auto resultTy = dyn_cast<BaseTensorType>(op.getType());
+    if (!resultTy || !resultTy.hasDtype())
+      return failure();
+
+    Type qdtype = resultTy.getDtype();
+    auto quantBounds = getQuantizedBounds(qdtype);
+    if (failed(quantBounds))
+      return failure();
+
+    Value operand = op.getSelf();
+    std::stack<Operation *> commutingOpStack;
+    for (unsigned depth = 0; depth < 5; ++depth) {
+      auto *currOp = operand.getDefiningOp();
+      if (!currOp)
+        break;
+      if (isQCommutingOp(currOp)) {
+        commutingOpStack.push(currOp);
+        operand = currOp->getOperand(0);
+        continue;
+      }
+      break;
+    }
+
+    auto inputDequant = operand.getDefiningOp<AtenDequantizeTensorOp>();
+    if (!inputDequant)
+      return failure();
+
+    auto inputQuant = inputDequant.getQtensor()
+                          .getDefiningOp<Aten_MakePerTensorQuantizedTensorOp>();
+    if (!inputQuant)
+      return failure();
+
+    auto inputQTy = dyn_cast<BaseTensorType>(inputDequant.getQtensor().getType());
+    if (!inputQTy || !inputQTy.hasDtype() || !isa<QInt32Type>(inputQTy.getDtype()))
+      return failure();
+
+    auto inputIntTy = dyn_cast<BaseTensorType>(inputQuant.getSelf().getType());
+    if (!inputIntTy || !inputIntTy.hasDtype() ||
+        !inputIntTy.getDtype().isInteger(32))
+      return failure();
+
+    double inputScale, outputScale;
+    int64_t inputZeroPoint, outputZeroPoint;
+    if (!matchPattern(inputQuant.getScale(), m_TorchConstantFloat(&inputScale)) ||
+        !matchPattern(op.getScale(), m_TorchConstantFloat(&outputScale)) ||
+        !matchPattern(inputQuant.getZeroPoint(),
+                      m_TorchConstantInt(&inputZeroPoint)) ||
+        !matchPattern(op.getZeroPoint(), m_TorchConstantInt(&outputZeroPoint)))
+      return failure();
+
+    if (inputScale <= 0.0 || outputScale <= 0.0)
+      return rewriter.notifyMatchFailure(op, "quantization scales must be > 0");
+
+    int32_t multiplier = 0;
+    int32_t shift = 0;
+    if (!tosa::computeMultiplierAndShift(inputScale / outputScale, multiplier,
+                                         shift, /*scaleWidth=*/32))
+      return rewriter.notifyMatchFailure(op, "failed to compute requant scale");
+
+    Location loc = op.getLoc();
+    Type i64Ty = rewriter.getIntegerType(64, IntegerType::Signed);
+    auto i64TensorTy = cast<BaseTensorType>(
+        inputIntTy.getWithSizesAndDtype(inputIntTy.getOptionalSizes(), i64Ty));
+    Value integerOperand = inputQuant.getSelf();
+    Type intDType =
+        cast<ValueTensorType>(inputQuant.getSelf().getType()).getOptionalDtype();
+    while (!commutingOpStack.empty()) {
+      auto *currOp = commutingOpStack.top();
+      commutingOpStack.pop();
+      SmallVector<Value> currOperands(currOp->getOperands());
+      currOperands[0] = integerOperand;
+      auto oldType = cast<ValueTensorType>(currOp->getResultTypes()[0]);
+      auto intType =
+          rewriter.getType<ValueTensorType>(oldType.getSizes(), intDType);
+      integerOperand =
+          rewriter
+              .create(loc, (currOp->getName()).getIdentifier(), currOperands,
+                      intType, currOp->getAttrs())
+              ->getResult(0);
+    }
+
+    auto integerOperandTy =
+        dyn_cast<BaseTensorType>(integerOperand.getType());
+    if (!integerOperandTy || !integerOperandTy.hasDtype() ||
+        !integerOperandTy.getDtype().isInteger(32))
+      return failure();
+    auto routedI64TensorTy = cast<BaseTensorType>(integerOperandTy.getWithSizesAndDtype(
+        integerOperandTy.getOptionalSizes(), i64Ty));
+    Value requant =
+        convertTensorToDtype(rewriter, loc, integerOperand, i64Ty);
+
+    Value one = ConstantIntOp::create(
+        rewriter, loc, rewriter.getType<Torch::IntType>(),
+        rewriter.getIntegerAttr(rewriter.getIntegerType(64), 1));
+    if (inputZeroPoint != 0) {
+      Value inputZp = ConstantIntOp::create(
+          rewriter, loc, rewriter.getType<Torch::IntType>(),
+          rewriter.getIntegerAttr(rewriter.getIntegerType(64), inputZeroPoint));
+      requant = AtenSubScalarOp::create(rewriter, loc, routedI64TensorTy, requant,
+                                        inputZp, one);
+    }
+
+    Value multiplierValue = ConstantIntOp::create(
+        rewriter, loc, rewriter.getType<Torch::IntType>(),
+        rewriter.getIntegerAttr(rewriter.getIntegerType(64), multiplier));
+    requant = AtenMulScalarOp::create(rewriter, loc, routedI64TensorTy, requant,
+                                      multiplierValue);
+
+    if (shift > 0) {
+      Value roundBias = ConstantIntOp::create(
+          rewriter, loc, rewriter.getType<Torch::IntType>(),
+          rewriter.getIntegerAttr(rewriter.getIntegerType(64),
+                                  int64_t{1} << (shift - 1)));
+      requant = AtenAddScalarOp::create(rewriter, loc, routedI64TensorTy, requant,
+                                        roundBias, one);
+      Value shiftValue = ConstantIntOp::create(
+          rewriter, loc, rewriter.getType<Torch::IntType>(),
+          rewriter.getIntegerAttr(rewriter.getIntegerType(64), shift));
+      requant = Aten__Rshift__ScalarOp::create(rewriter, loc, routedI64TensorTy,
+                                               requant, shiftValue);
+    }
+
+    if (outputZeroPoint != 0) {
+      Value outputZp = ConstantIntOp::create(
+          rewriter, loc, rewriter.getType<Torch::IntType>(),
+          rewriter.getIntegerAttr(rewriter.getIntegerType(64), outputZeroPoint));
+      requant = AtenAddScalarOp::create(rewriter, loc, routedI64TensorTy, requant,
+                                        outputZp, one);
+    }
+
+    auto [qmin, qmax] = *quantBounds;
+    Value qminValue = ConstantIntOp::create(
+        rewriter, loc, rewriter.getType<Torch::IntType>(),
+        rewriter.getIntegerAttr(rewriter.getIntegerType(64), qmin));
+    Value qmaxValue = ConstantIntOp::create(
+        rewriter, loc, rewriter.getType<Torch::IntType>(),
+        rewriter.getIntegerAttr(rewriter.getIntegerType(64), qmax));
+    requant = AtenClampOp::create(rewriter, loc, routedI64TensorTy, requant, qminValue,
+                                  qmaxValue);
+
+    Type storageTy = getStorageTypeForQuantizedDtype(rewriter.getContext(), qdtype);
+    if (!storageTy)
+      return failure();
+
+    Value storage = convertTensorToDtype(rewriter, loc, requant, storageTy);
+
+    rewriter.replaceOpWithNewOp<Aten_MakePerTensorQuantizedTensorOp>(
+        op, resultTy, storage, op.getScale(), op.getZeroPoint());
+    return success();
+  }
+};
