+static FailureOr<DenseElementsAttr> getDenseElementsAttr(Value value) {
+  auto literal = value.getDefiningOp<ValueTensorLiteralOp>();
+  if (!literal)
+    return failure();
+
+  auto valueAttr = literal.getValueAttr();
+  if (auto denseAttr = dyn_cast<DenseElementsAttr>(valueAttr))
+    return denseAttr;
+
+  auto resourceAttr = dyn_cast<DenseResourceElementsAttr>(valueAttr);
+  if (!resourceAttr)
+    return failure();
+
+  auto *blob = resourceAttr.getRawHandle().getBlob();
+  if (!blob)
+    return failure();
+
+  return DenseElementsAttr::getFromRawBuffer(
+      cast<ShapedType>(resourceAttr.getType()), blob->getData());
+}
+
+static FailureOr<DenseElementsAttr>
+quantizeFloatLiteralToInt(DenseElementsAttr denseAttr, ShapedType targetType,
+                          double scale, int64_t zeroPoint) {
+  auto sourceType = dyn_cast<ShapedType>(denseAttr.getType());
+  if (!sourceType || !isa<mlir::FloatType>(sourceType.getElementType()))
+    return failure();
+
+  auto targetElemType = dyn_cast<IntegerType>(targetType.getElementType());
+  if (!targetElemType)
+    return failure();
+
+  auto clampToTargetRange = [&](int64_t value) -> int64_t {
+    unsigned width = targetElemType.getWidth();
+    bool isUnsigned = targetElemType.isUnsignedInteger();
+    if (!isUnsigned) {
+      int64_t minValue = -(int64_t{1} << (width - 1));
+      int64_t maxValue = (int64_t{1} << (width - 1)) - 1;
+      return std::clamp(value, minValue, maxValue);
+    }
+    int64_t maxValue = (int64_t{1} << width) - 1;
+    return std::clamp<int64_t>(value, 0, maxValue);
+  };
+
+  auto quantizeFloat = [&](const APFloat &value) -> APInt {
+    int64_t quantized =
+        std::llround(value.convertToDouble() / scale) + zeroPoint;
+    quantized = clampToTargetRange(quantized);
+    return APInt(targetElemType.getWidth(), quantized,
+                 /*isSigned=*/!targetElemType.isUnsignedInteger());
+  };
+
+  if (denseAttr.isSplat())
+    return success(DenseElementsAttr::get(
+        targetType, quantizeFloat(denseAttr.getSplatValue<APFloat>())));
+
+  SmallVector<Attribute> values;
+  values.reserve(denseAttr.getNumElements());
+  for (APFloat value : denseAttr.getValues<APFloat>())
+    values.push_back(IntegerAttr::get(targetElemType, quantizeFloat(value)));
+  return success(DenseElementsAttr::get(targetType, values));
+}
