+class RemoveIdentityContiguous : public OpRewritePattern<AtenContiguousOp> {
+public:
+  using OpRewritePattern<AtenContiguousOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(AtenContiguousOp op,
+                                PatternRewriter &rewriter) const override {
+    if (op.getSelf().getType() != op.getType())
+      return failure();
+    rewriter.replaceOp(op, op.getSelf());
+    return success();
+  }
+};
