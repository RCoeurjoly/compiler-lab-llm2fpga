+static FailureOr<std::pair<int64_t, int64_t>>
+getQuantizedBounds(Type qdtype) {
+  if (isa<QInt8Type>(qdtype))
+    return success(std::make_pair(int64_t{-128}, int64_t{127}));
+  if (isa<QUInt8Type>(qdtype))
+    return success(std::make_pair(int64_t{0}, int64_t{255}));
+  return failure();
