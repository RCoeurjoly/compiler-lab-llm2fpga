+class RemoveRedundantClampAfterQuantize
+    : public OpRewritePattern<AtenClampOp> {
+public:
+  using OpRewritePattern<AtenClampOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(AtenClampOp op,
+                                PatternRewriter &rewriter) const override {
+    auto resultTy = dyn_cast<BaseTensorType>(op.getType());
+    if (!resultTy || !resultTy.hasDtype())
+      return failure();
+
+    auto intRepr = op.getSelf().getDefiningOp<AtenIntReprOp>();
+    Value passthrough = op.getSelf();
+    if (!intRepr) {
+      auto innerClamp = op.getSelf().getDefiningOp<AtenClampOp>();
+      if (!innerClamp)
+        return failure();
+      intRepr = innerClamp.getSelf().getDefiningOp<AtenIntReprOp>();
+      if (!intRepr)
+        return failure();
+      passthrough = innerClamp.getResult();
+    }
+
+    auto quant = intRepr.getSelf().getDefiningOp<AtenQuantizePerTensorOp>();
+    if (!quant)
+      return failure();
+
+    auto qTy = dyn_cast<BaseTensorType>(quant.getType());
+    if (!qTy || !qTy.hasDtype())
+      return failure();
+
+    auto quantBounds = getQuantizedBounds(qTy.getDtype());
+    if (failed(quantBounds))
+      return failure();
+    auto [qmin, qmax] = *quantBounds;
+
+    int64_t minValue, maxValue;
+    if (!matchPattern(op.getMin(), m_TorchConstantInt(&minValue)) ||
+        !matchPattern(op.getMax(), m_TorchConstantInt(&maxValue)))
+      return failure();
+
+    if (minValue != qmin || maxValue != qmax)
+      return failure();
+
+    rewriter.replaceOp(op, passthrough);
+    return success();
+  }
+};
