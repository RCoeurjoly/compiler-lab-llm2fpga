+class QuantizeBiasAddAfterQMatmul : public OpRewritePattern<AtenAddTensorOp> {
+public:
+  using OpRewritePattern<AtenAddTensorOp>::OpRewritePattern;
+
+  LogicalResult matchAndRewrite(AtenAddTensorOp op,
+                                PatternRewriter &rewriter) const override {
+    auto resultTy = dyn_cast<BaseTensorType>(op.getType());
+    if (!resultTy || !resultTy.hasDtype() ||
+        !isa<mlir::FloatType>(resultTy.getDtype()))
+      return failure();
+
+    auto lhsDequant = op.getSelf().getDefiningOp<AtenDequantizeTensorOp>();
+    if (!lhsDequant)
+      return failure();
+
+    auto lhsQuant =
+        lhsDequant.getQtensor().getDefiningOp<Aten_MakePerTensorQuantizedTensorOp>();
+    if (!lhsQuant)
+      return failure();
+
+    auto lhsInt = lhsQuant.getSelf();
+    auto lhsIntTy = dyn_cast<BaseTensorType>(lhsInt.getType());
+    if (!lhsIntTy || !lhsIntTy.hasDtype() || !lhsIntTy.getDtype().isInteger(32))
+      return failure();
+
+    Value alpha = op.getAlpha();
+    int64_t alphaValue;
+    if (!matchPattern(alpha, m_TorchConstantInt(&alphaValue)) ||
+        alphaValue != 1) {
+      return rewriter.notifyMatchFailure(op, "only alpha=1 is supported");
+    }
+
+    int64_t zeroPoint;
+    if (!matchPattern(lhsQuant.getZeroPoint(), m_TorchConstantInt(&zeroPoint)) ||
+        zeroPoint != 0) {
+      return rewriter.notifyMatchFailure(
+          op, "only zero-point 0 quantized accumulators are supported");
+    }
+
+    auto biasTy = dyn_cast<BaseTensorType>(op.getOther().getType());
+    if (!biasTy || !biasTy.hasDtype() || !isa<mlir::FloatType>(biasTy.getDtype()))
+      return failure();
+
+    auto qi32Ty = rewriter.getType<QInt32Type>();
+    Value scale = lhsQuant.getScale();
+    Value zero = lhsQuant.getZeroPoint();
+
+    auto qBiasTy = cast<BaseTensorType>(
+        biasTy.getWithSizesAndDtype(biasTy.getOptionalSizes(), qi32Ty));
+    auto biasIntTy = cast<BaseTensorType>(biasTy.getWithSizesAndDtype(
+        biasTy.getOptionalSizes(),
+        rewriter.getIntegerType(32, IntegerType::Signed)));
+    Value biasInt;
+    Value qBias;
+    auto denseAttr = getDenseElementsAttr(op.getOther());
+    if (succeeded(denseAttr)) {
+      double scaleValue;
+      if (!matchPattern(scale, m_TorchConstantFloat(&scaleValue)) ||
+          scaleValue <= 0.0) {
+        return rewriter.notifyMatchFailure(
+            op, "literal bias requires a positive constant scale");
+      }
+
+      auto denseType = cast<ShapedType>(denseAttr->getType());
+      auto biasIntLiteralType =
+          RankedTensorType::get(denseType.getShape(), rewriter.getI32Type());
+      auto quantizedBiasAttr =
+          quantizeFloatLiteralToInt(*denseAttr, biasIntLiteralType, scaleValue,
+                                    zeroPoint);
+      if (failed(quantizedBiasAttr)) {
+        return rewriter.notifyMatchFailure(
+            op, "failed to quantize literal bias to int32");
+      }
+
+      biasInt = ValueTensorLiteralOp::create(rewriter, op.getLoc(),
+                                             *quantizedBiasAttr);
+      biasInt = adjustStaticInformation(rewriter, op.getLoc(), biasInt,
+                                        biasIntTy, /*userAllowsRefinement=*/false);
+      qBias = Aten_MakePerTensorQuantizedTensorOp::create(
+          rewriter, op.getLoc(), qBiasTy, biasInt, scale, zero);
+    } else {
+      qBias = AtenQuantizePerTensorOp::create(
+          rewriter, op.getLoc(), qBiasTy, op.getOther(), scale, zero,
+          getDtypeIntValueForType(rewriter, op.getLoc(), qi32Ty));
+      biasInt =
+          AtenIntReprOp::create(rewriter, op.getLoc(), biasIntTy, qBias);
+    }
+
+    auto addIntTy = cast<BaseTensorType>(resultTy.getWithSizesAndDtype(
+        resultTy.getOptionalSizes(), biasIntTy.getDtype()));
+    Value addInt = AtenAddTensorOp::create(rewriter, op.getLoc(), addIntTy,
+                                           lhsInt, biasInt, alpha);
+    auto qOutTy = cast<BaseTensorType>(
+        resultTy.getWithSizesAndDtype(resultTy.getOptionalSizes(), qi32Ty));
+    Value qOut = Aten_MakePerTensorQuantizedTensorOp::create(
+        rewriter, op.getLoc(), qOutTy, addInt, scale, zero);
+    rewriter.replaceOpWithNewOp<AtenDequantizeTensorOp>(op, resultTy, qOut);
+    return success();
+  }
+};
