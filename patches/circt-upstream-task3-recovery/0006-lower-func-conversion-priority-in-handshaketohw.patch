From 7cf07bbc70d26e8c227aa24a4cdba47411da7ec6 Mon Sep 17 00:00:00 2001
From: Roland Coeurjoly <rolandcoeurjoly@gmail.com>
Date: Mon, 20 Apr 2026 12:12:44 +0200
Subject: [PATCH] Lower func conversion priority in HandshakeToHW

---
 lib/Conversion/HandshakeToHW/HandshakeToHW.cpp | 14 ++++++++++++--
 1 file changed, 12 insertions(+), 2 deletions(-)

diff --git a/lib/Conversion/HandshakeToHW/HandshakeToHW.cpp b/lib/Conversion/HandshakeToHW/HandshakeToHW.cpp
index 30a550c4b..83c9e8d04 100644
--- a/lib/Conversion/HandshakeToHW/HandshakeToHW.cpp
+++ b/lib/Conversion/HandshakeToHW/HandshakeToHW.cpp
@@ -1907,7 +1907,9 @@ private:
 
 class FuncOpConversionPattern : public OpConversionPattern<handshake::FuncOp> {
 public:
-  using OpConversionPattern::OpConversionPattern;
+  FuncOpConversionPattern(TypeConverter &typeConverter, MLIRContext *context)
+      : OpConversionPattern(typeConverter, context,
+                            PatternBenefit(/*benefit=*/0)) {}
 
   LogicalResult
   matchAndRewrite(handshake::FuncOp op, OpAdaptor operands,
@@ -1978,7 +1980,7 @@ static LogicalResult convertFuncOp(ESITypeConverter &typeConverter,
                                    instanceUniquer};
   RewritePatternSet patterns(op.getContext());
   patterns.insert<FuncOpConversionPattern, ReturnConversionPattern,
-                  AssertConversionPattern>(op.getContext());
+                  AssertConversionPattern>(typeConverter, op.getContext());
   patterns.insert<JoinConversionPattern, ForkConversionPattern,
                   SyncConversionPattern>(typeConverter, op.getContext(),
                                          moduleBuilder, ls);
@@ -2060,6 +2062,14 @@ public:
                       hw::InstanceOp>();
     target
         .addIllegalDialect<handshake::HandshakeDialect, arith::ArithDialect>();
+    target.addDynamicallyLegalOp<handshake::FuncOp>(
+        [&](handshake::FuncOp funcOp) {
+          return typeConverter.isSignatureLegal(funcOp.getFunctionType()) &&
+                 llvm::all_of(funcOp.getBody().getOps(),
+                              [&](Operation &nestedOp) {
+                                return target.isLegal(&nestedOp);
+                              });
+        });
     target.addIllegalOp<cf::AssertOp>();
     target.addIllegalDialect<math::MathDialect>();
 
-- 
2.53.0

