+template <typename TosaOpT>
+static FailureOr<Value>
+rewriteNarrowIntegerAddSub(PatternRewriter &rewriter, Operation *op,
+                           TensorType outType, Value lhs, Value rhs) {
+  auto outElemTy = dyn_cast<IntegerType>(outType.getElementType());
+  if (!outElemTy || outElemTy.getWidth() >= 32)
+    return failure();
+
+  // TOSA elementwise add/sub (tosa::AddOp/tosa::SubOp) does not accept i8/i16
+  // tensor arithmetic in the profiles used by this pipeline. Widen the
+  // arithmetic to i32 and then cast back to the expected narrow result type.
+  auto wideType = outType.clone(rewriter.getI32Type());
+  auto lhsWide = tosa::tosaCastTensorToType(rewriter, lhs, wideType);
+  if (!lhsWide)
+    return failure();
+
+  auto rhsWide = tosa::tosaCastTensorToType(rewriter, rhs, wideType);
+  if (!rhsWide)
+    return failure();
+
+  auto wideAddOrSub = tosa::CreateOpAndInfer<TosaOpT>(
+      rewriter, op->getLoc(), wideType, *lhsWide, *rhsWide);
+  auto narrowed =
+      tosa::tosaCastTensorToType(rewriter, wideAddOrSub.getResult(), outType);
+  if (!narrowed)
+    return failure();
+  return *narrowed;
+}
